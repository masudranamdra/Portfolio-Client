# ============================================
# ENVIRONMENT CONFIGURATION - PORTFOLIO APP
# ============================================

# ============================================
# MONGODB DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# MongoDB database name
MONGODB_DB=portfolio

# ============================================
# BETTER AUTH CONFIGURATION
# ============================================
# Secret key for Better Auth (minimum 32 characters for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=your_secure_better_auth_secret_minimum_32_characters_change_in_production

# Better Auth base URL
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# NEXT.JS PUBLIC CONFIGURATION
# ============================================
# Application URL (used for redirects and CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API URL for frontend API calls
NEXT_PUBLIC_API_URL=/api

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
# Get these from: https://console.cloud.google.com/
# Google OAuth Client ID (public - safe to expose)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google OAuth Client Secret (keep this secret - never commit to repo!)
GOOGLE_CLIENT_SECRET=your_google_client_secret_keep_this_secret

# ============================================
# EMAIL CONFIGURATION (Optional - for password reset)
# ============================================
# Gmail address for sending reset emails
EMAIL_USER=your-email@gmail.com

# Gmail App Password (not regular password - use app-specific password from Google Account)
# Get this from: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_gmail_app_password

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
# Google OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id

# Google OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# ADMIN EMAIL CONFIGURATION
# ============================================
# Add multiple emails separated by commas
ADMIN_EMAILS=admin@gmail.com
